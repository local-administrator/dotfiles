// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "show_edit_predictions": true,
  "edit_predictions": {
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
      "enterprise_uri": null
    },
    "enabled_in_text_threads": false
  },
  "agent": {
    "default_profile": "ask",
    "model_parameters": [],
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-thinking-latest"
    },
  },
  "project_panel": {
    "dock": "left"
  },
  "icon_theme": "Catppuccin Frappé",
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "vim_mode": false,
  "theme": "Catppuccin Frappé",
  "ui_font_size": 15,
  "buffer_font_size": 14,
  "buffer_line_height": "comfortable",
  "buffer_font_family": "Hack",
  "tab_size": 2,
  "wrap_guides": [80],
  "cursor_blink": true,
  "relative_line_numbers": true,
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false
  },
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  "terminal": {
    "dock": "bottom",
    "font_size": 14,
    "font_family": "JetBrainsMono Nerd Font",
    "copy_on_select": true,
    "shell": {
      "program": "/opt/homebrew/bin/fish"
    }
  },
  "preferred_line_length": 80,
  //"formatter": "prettier",
  "autosave": "on_focus_change",
  "autosave_delay": 1500,
  "autosave_on_focus_change": true,
  "autosave_on_window_change": true,
  "hover_popover_enabled": true,
  "show_copilot_suggestions": true,
  "inlay_hints": {
    "enabled": true,
    "typeHints": true,
    "parameterHints": true,
    "chainingHints": true
  },
  "language_models": {
    "openai": {
      "api_url": "https://WORK_PROXY_URL/v1"
    },
    "anthropic": {
      "api_url": "https://WORK_PROXY_URL/vendors/anthropic"
    }
  },
  "features": {
    "edit_prediction_provider": "copilot"
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
    "background_coloring": "indent_aware"
  },
  "languages": {
    "Ruby": {
      "show_edit_predictions": false,
      "language_servers": ["ruby-lsp", "rubocop"]
    }
  },
  "lsp": {
    "rubocop": {
      "initialization_options": {
        "safeAutocorrect": false
      }
    },
    "ruby-lsp": {
      "initialization_options": {
        "enabledFeatures": {
          // This disables diagnostics
          "diagnostics": false
        }
      }
    }
  }
}
